rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection: Users can only read and write their own documents
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Leaderboard Collection: Anyone can read, but only authenticated users can write/update their own entries
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Community Posts: Anyone can read. Only authenticated users can create. Only the author can update/delete.
    // Allow any authenticated user to update the votes/score field (for upvoting/downvoting)
    match /community_posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // Safety Reports: Anyone can read. Authenticated users can create or update (for confirmations)
    match /safety_reports/{reportId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isAuthenticated();
      allow delete: if false; // Reports should only naturally expire
    }

    // Events: Anyone can read. Authenticated users can update RSVPs
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Submissions: Anyone can read. Authenticated users can create or update (confirmations)
    match /submissions/{submissionId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.submitterId == request.auth.uid;
      allow update: if isAuthenticated();
      allow delete: if false;
    }
    
    // Checkins & Activity: Subcollections under user
    match /users/{userId}/checkins/{checkinId} {
      allow read, write: if isOwner(userId);
    }
    
    match /users/{userId}/activity/{activityId} {
      allow read, write: if isOwner(userId);
    }

  }
}
